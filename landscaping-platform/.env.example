# =============================================================================
# LANDSCAPING PLATFORM - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and update values for your environment

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# Frontend URL (for CORS)
CORS_ORIGIN=http://localhost:5173

# JWT Secret (CHANGE IN PRODUCTION - use a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=landscape
POSTGRES_PASSWORD=postgres
POSTGRES_DB=landscaping

# Connection string (constructed from above, but can override)
# DATABASE_URL=postgresql://landscape:postgres@localhost:5432/landscaping

# -----------------------------------------------------------------------------
# MinIO S3 Configuration
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# -----------------------------------------------------------------------------
# API Gateway Ports
# -----------------------------------------------------------------------------
API_GATEWAY_PORT=3001

# -----------------------------------------------------------------------------
# AI Service Configuration
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# -----------------------------------------------------------------------------
# Auth.js Configuration (if using Auth.js adapters)
# -----------------------------------------------------------------------------
# AUTH_SECRET=your-auth-secret
# AUTH_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Collaboration Server
# -----------------------------------------------------------------------------
COLLABORATION_PORT=1234
